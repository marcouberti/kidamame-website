    "makesOffer": {
      "@type": "Offer",
      "itemOffered": {
        "@type": "SoftwareApplication",
        "name": "Educational Apps for Kids",
        "applicationCategory": "Educational",
        "operatingSystem": "iOS, Android",
        "description": "Kidamame creates calm, ad-free apps for kids 4-10. Fostering curiosity through art, nature & storytelling. 100% offline: no noise, no manipulative mechanics."
      }
    }
  }
  </script>

  <!-- Cookiebot when needed, not now since we don't use cookies -->
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="8b9ca4b0-be72-4a83-ba31-a58229109c03"
    data-blockingmode="auto" type="text/javascript"></script>

  <!-- Favicon declarations -->
  <link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png">

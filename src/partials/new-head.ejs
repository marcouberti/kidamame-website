  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1b2a3b">
  <title>
    <%= locals.title || 'Kidamame | Safe, quiet spaces that inspire kids to explore the world beyond the screen.' %>
  </title>
  <link
    href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <style>
    #CookiebotWidget {
      display: none !important;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --blue: #59acff;
      --blue-light: #EAF5FF;
      --blue-mid: #C5E5F8;
      --blue-deep: #1A5F8E;
      --blue-darker: #0D3D60;
      --amber: #F5A52A;
      --amber-soft: #FFF8EE;
      --cream: #FDFCF8;
      --ink: #1B2A3B;
      --ink-soft: #5A6A7A;
      --white: #FFFFFF;
      --font-display: 'Baloo 2', cursive;
      --font-body: 'Nunito', sans-serif;
      --r-pill: 999px;
    }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
    }

    body {
      font-family: var(--font-body);
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.85rem 3rem;
      background: transparent;
      transition: background 0.3s, box-shadow 0.3s;
    }

    nav.scrolled {
      background: var(--white);
      box-shadow: 0 4px 24px rgba(58, 158, 228, 0.10);
      border-bottom: 1.5px solid rgba(58, 158, 228, 0.1);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      text-decoration: none;
    }

    .nav-logo img {
      height: 42px;
      width: auto;
      display: block;
    }

    .nav-logo-text {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.95);
      letter-spacing: 0.02em;
      transition: color 0.3s;
    }

    .nav-logo-text sup {
      font-size: 0.55em;
      opacity: 0.6;
      margin-left: 0.05em;
    }

    nav.scrolled .nav-logo-text {
      color: var(--ink);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.9);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav.scrolled .nav-links a {
      color: var(--ink-soft);
    }

    .nav-links a:hover {
      color: white;
    }

    nav.scrolled .nav-links a:hover {
      color: var(--blue);
    }

    .nav-cta {
      font-family: var(--font-body);
      font-size: 0.84rem;
      font-weight: 800;
      padding: 0.5rem 1.35rem;
      background: white;
      color: var(--blue-deep);
      border-radius: var(--r-pill);
      text-decoration: none;
      box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);
      transition: transform 0.15s, box-shadow 0.15s;
    }

    nav.scrolled .nav-cta {
      background: var(--blue);
      color: white;
      box-shadow: 0 3px 12px rgba(58, 158, 228, 0.3);
    }

    .nav-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 5px 16px rgba(0, 0, 0, 0.18);
    }

    /* ── HERO ── */
    .hero {
      width: 100%;
      min-height: 100vh;
      background: var(--blue);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    /* Animated organic background blobs */
    .hero-bubble {
      position: absolute;
      background: rgba(255, 255, 255, 0.07);
      pointer-events: none;
      animation: morphBlob 20s infinite alternate ease-in-out;
    }

    .hero-bubble-1 {
      width: 650px;
      height: 650px;
      top: -150px;
      right: -100px;
      animation-duration: 22s;
    }

    .hero-bubble-2 {
      width: 450px;
      height: 450px;
      bottom: -100px;
      left: -80px;
      background: rgba(255, 255, 255, 0.05);
      animation-duration: 26s;
      animation-delay: -5s;
    }

    .hero-bubble-3 {
      width: 250px;
      height: 250px;
      top: 15%;
      left: 10%;
      background: rgba(255, 255, 255, 0.035);
      animation-duration: 18s;
      animation-delay: -10s;
    }

    @keyframes morphBlob {
      0% {
        border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
        transform: translate(0, 0) rotate(0deg) scale(1);
      }

      50% {
        border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
        transform: translate(-30px, 20px) rotate(15deg) scale(1.05);
      }

      100% {
        border-radius: 50% 50% 40% 60% / 40% 40% 60% 60%;
        transform: translate(20px, -20px) rotate(-10deg) scale(0.95);
      }
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      padding: 8rem 5rem 6rem;
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 4rem;
      align-items: stretch;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-logo-img {
      width: 200px;
      margin-bottom: 2rem;
      animation: fadeUp 0.7s ease both;
    }

    .hero-tagline {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 1.1rem;
      animation: fadeUp 0.7s 0.1s ease both;
    }

    .hero-text h1 {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 3.8vw, 3.6rem);
      font-weight: 800;
      line-height: 1.2;
      color: white;
      animation: fadeUp 0.7s 0.2s ease both;
    }

    .hero-text h1 span {
      color: rgba(255, 255, 255, 0.75);
      font-weight: 600;
    }

    .hero-desc {
      margin-top: 1.4rem;
      font-size: 1rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.8);
      max-width: 420px;
      line-height: 1.8;
      animation: fadeUp 0.7s 0.3s ease both;
    }

    .hero-actions {
      display: flex;
      gap: 0.9rem;
      margin-top: 2.5rem;
      flex-wrap: wrap;
      animation: fadeUp 0.7s 0.4s ease both;
      max-width: 540px;
    }

    .hero-actions a {
      flex: 1;
      justify-content: center;
      text-align: center;
      min-width: 220px;
      white-space: nowrap;
    }

    .btn-white {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 0.9rem;
      padding: 0.8rem 1.9rem;
      background: white;
      color: var(--blue-deep);
      border-radius: var(--r-pill);
      text-decoration: none;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14);
      transition: transform 0.15s, box-shadow 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-white:hover {
      transform: translateY(-2px);
      box-shadow: 0 7px 22px rgba(0, 0, 0, 0.2);
    }

    .btn-ghost {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 0.9rem;
      padding: 0.8rem 1.9rem;
      background: transparent;
      color: white;
      border: 2px solid rgba(255, 255, 255, 0.45);
      border-radius: var(--r-pill);
      text-decoration: none;
      transition: background 0.2s, border-color 0.2s;
    }

    .btn-primary {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 0.9rem;
      padding: 0.8rem 1.9rem;
      background: var(--blue);
      color: white;
      border-radius: var(--r-pill);
      text-decoration: none;
      box-shadow: 0 4px 14px rgba(89, 172, 255, 0.4);
      transition: transform 0.15s, box-shadow 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 7px 22px rgba(89, 172, 255, 0.5);
    }

    .btn-ghost:hover {
      background: rgba(255, 255, 255, 0.12);
      border-color: white;
    }

    .hero-stores {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-top: 1.8rem;
      animation: fadeUp 0.7s 0.5s ease both;
    }

    .hero-stores-label {
      font-size: 0.72rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.55);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .store-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      background: rgba(255, 255, 255, 0.12);
      border: 1.5px solid rgba(255, 255, 255, 0.28);
      border-radius: 10px;
      padding: 0.38rem 0.9rem;
      font-size: 0.78rem;
      font-weight: 700;
      color: white;
      text-decoration: none;
      transition: background 0.2s;
    }

    .store-badge:hover {
      background: rgba(255, 255, 255, 0.22);
    }

    .store-badge i {
      font-size: 0.85rem;
    }

    .hero-visual {
      display: flex;
      align-items: stretch;
      justify-content: center;
      height: 0;
      min-height: 100%;
      animation: fadeUp 0.8s 0.3s ease both;
    }

    .hero-visual-box {
      width: 100%;
      max-width: 640px;
      height: 100%;
      border-radius: 28px;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.22);
      overflow: hidden;
      position: relative;
    }

    .hero-visual-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(22px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── TRUST BAR ── */
    .trust-bar {
      background: var(--white);
      border-bottom: 1px solid rgba(58, 158, 228, 0.1);
      padding: 1.2rem 3rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2.8rem;
      flex-wrap: wrap;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-family: var(--font-body);
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--ink-soft);
    }

    .trust-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: var(--blue-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--blue);
      font-size: 0.9rem;
    }

    /* Shared styles */

    /* ── SHARED ── */
    section {
      padding: 6rem 2rem;
    }

    .container {
      max-width: 1040px;
      margin: 0 auto;
    }

    .section-label {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 0.9rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 3vw, 2.7rem);
      font-weight: 800;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 1.1rem;
    }

    .section-title em {
      font-style: italic;
      color: var(--blue);
      font-weight: 700;
    }

    .section-sub {
      font-size: 1rem;
      color: var(--ink-soft);
      line-height: 1.78;
    }

    /* ── MISSION ── */
    .mission {
      background: var(--blue-light);
    }

    .mission-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .mission-quote {
      background: var(--blue);
      border-radius: 28px;
      padding: 2.8rem 2.5rem;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .mission-quote::before {
      content: '\201C';
      position: absolute;
      top: -30px;
      left: 14px;
      font-family: Georgia, serif;
      font-size: 14rem;
      color: rgba(255, 255, 255, 0.07);
      line-height: 1;
      pointer-events: none;
    }

    .mission-quote p {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1.7;
      position: relative;
      z-index: 1;
    }

    .mission-quote .quote-source {
      margin-top: 1.5rem;
      font-family: var(--font-body);
      font-size: 0.79rem;
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.55);
      position: relative;
      z-index: 1;
    }

    .mission-pillars {
      display: flex;
      flex-direction: column;
      gap: 1.1rem;
    }

    .pillar {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.2rem 1.4rem;
      background: white;
      border-radius: 18px;
      border: 1.5px solid rgba(58, 158, 228, 0.11);
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .pillar:hover {
      box-shadow: 0 6px 24px rgba(58, 158, 228, 0.11);
      transform: translateY(-2px);
    }

    .pillar-icon {
      width: 44px;
      height: 44px;
      flex-shrink: 0;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
    }

    .pillar-text h4 {
      font-family: var(--font-display);
      font-size: 0.97rem;
      font-weight: 700;
      margin-bottom: 0.2rem;
    }

    .pillar-text p {
      font-size: 0.84rem;
      color: var(--ink-soft);
      line-height: 1.55;
    }

    /* ── PRODUCT ── */
    .product {
      background: var(--white);
    }

    .product-simple-content {
      margin-top: 2.5rem;
    }

    .product-simple-content p {
      font-size: 1.05rem;
      color: var(--ink-soft);
      line-height: 1.8;
      margin-bottom: 2.5rem;
    }

    .product-simple-content p strong {
      color: var(--ink);
      font-weight: 700;
    }

    .simple-gallery {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .simple-gallery .landscape {
      grid-column: 1 / -1;
      width: 100%;
      height: auto;
    }

    .mission .simple-gallery {
      grid-template-columns: 1fr;
    }

    .simple-gallery img {
      width: 100%;
      height: auto;
      border-radius: 20px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .simple-gallery img:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    }

    .store-badges {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 2.5rem;
    }

    .store-badges a {
      display: inline-block;
      text-decoration: none;
      transition: transform 0.2s;
    }

    .store-badges a:hover {
      transform: translateY(-2px);
    }

    .store-badges img {
      height: 54px;
      width: auto;
      display: block;
    }

    /*
    @media (max-width: 480px) {
      .store-badges img {
        height: auto;
        width: 180px;
      }
    }
    */

    /* ── VALUES ── */
    .values {
      background: var(--blue-light);
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.4rem;
      margin-top: 3rem;
    }

    .value-card {
      background: white;
      border-radius: 22px;
      padding: 1.8rem;
      border: 1.5px solid var(--blue-light);
      transition: transform 0.2s;
    }

    .value-card:hover {
      transform: translateY(-3px);
      /*box-shadow: 0 8px 28px var(--blue);*/
    }

    .value-card-icon {
      width: 46px;
      height: 46px;
      border-radius: 14px;
      background: var(--blue-light);

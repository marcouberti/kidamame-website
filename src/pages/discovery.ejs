<!DOCTYPE html>
<html lang="en">
<%- include('../partials/new-head', { title: 'Kidamame Discovery | The Calm App for Kids' , url: 'https://www.kidamame.com/discovery.html' }) %>

<body>
    <%- include('../partials/new-nav', { alwaysScrolled: true, hideNavItems: false }) %>

    <main style="padding-top: 100px; background: var(--white);">
      <!-- PRODUCT -->
      <section class="product" id="apps" style="padding-top: 4rem;">
        <div class="container">
          <p class="section-label reveal"><i class="fa-solid fa-mobile-screen"></i> &nbsp;Our app</p>
          <h2 class="section-title reveal">Meet <em>Kidamame Discovery</em></h2>

          <div class="product-simple-content reveal">
            <p>
              Welcome to <strong>Kidamame Discovery</strong>, our calm, interactive world designed for families. Rooted
              in <strong>Montessori principles</strong>, this experience offers <strong>meaningful screen time</strong>
              for children ages 4-10. We replace fast-paced goals and instructions with <strong>child-led
                exploration</strong>, inviting kids to touch, play, and learn at their own pace. Each
              <strong>sensory-rich</strong> scene is an illustrated storybook come to life, where tapping an animal or
              plant reveals beautiful "Did You Know?" cards. It’s a magical, ad-free space for families to slow down,
              spark <strong>curiosity</strong>, and share moments of wonder together.
            </p>

            <div class="simple-gallery">
              <img src="images/gallery/thumbs/artic_card.webp"
                alt="A wildlife educational app screenshot in the Artic featuring a polar bear with its cub"
                loading="lazy" />
              <img src="images/gallery/thumbs/11.webp"
                alt="A wildlife educational app screenshot in the African Savannah with mount Kilimanjaro"
                loading="lazy" />
              <img src="images/gallery/thumbs/13.webp"
                alt="A wildlife educational app screenshot in the Australian Red Center with Uluru and a kangaroo"
                loading="lazy" />
              <img src="images/gallery/thumbs/amazon_forest.webp"
                alt="A wildlife educational app screenshot in the Amazon forest featuring a tucan and a macaw parrot"
                loading="lazy" />
              <img src="images/gallery/thumbs/05.webp"
                alt="A wildlife educational app screenshot in the Alps featuring a bear and interesting facts about the bear"
                loading="lazy" />
            </div>

            <div class="reveal"
              style="text-align: center; margin-top: 3.5rem; background: var(--blue-light); padding: 2.5rem 2rem; border-radius: 20px;">
              <h4
                style="font-family: var(--font-display); font-size: 1.4rem; font-weight: 800; color: var(--blue); margin-bottom: 0.8rem;">
                Stay in the loop!
              </h4>
              <p
                style="font-size: 0.95rem; color: var(--ink-soft); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.6;">
                Want to be the first to know when <strong>Kidamame Discovery</strong> launches on the Google Play Store and the Apple App Store? Sign
                up
                to our newsletter for updates, behind-the-scenes content, and early access opportunities!
              </p>
              <a href="https://kidamame.substack.com/subscribe" target="_blank" rel="noopener noreferrer"
                class="btn-primary">
                ✨ Join our newsletter
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <%- include('../partials/new-footer') %>
</body>
</html>
